---
// 引入刚刚建好的皮肤
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="博雅的数字领地">
    
    <div class="hero">
        <h1>Hi, 我是山谷.</h1>
        <p>探索 M4 芯片的算力极限，用极简代码构建高级数字美学。这不仅是一个页面，这是我的互联网折跃点。</p>
    </div>

    <div class="section">
        <h2>我的引力场 (Hobbies)</h2>
        <div class="tags">
            <span class="tag">极客硬件</span>
            <span class="tag">系统自动化</span>
            <span class="tag">技术学习</span>
            <span class="tag">小游戏</span>
            <span class="tag">独立摄影</span>
        </div>
    </div>

    <div class="section">
        <h2>访客终端 (Message Board)</h2>
        <div class="message-box">
            <textarea id="msgInput" placeholder="留下你的坐标或思绪..."></textarea>
            <button id="sendBtn">发送数据</button>
        </div>
        <div id="msgList">
            </div>
    </div>

    <script>
        // Astro 会自动保证 DOM 加载完毕后再执行这里，所以直接奔入主题！
        
        // 1. 页面一出来，立刻加载历史留言
        loadMessages();
        
        // 2. 找到按钮，绑定点击开火事件
        const btn = document.getElementById('sendBtn');
        if (btn) {
            btn.addEventListener('click', leaveMessage);
        }

        // 核心逻辑函数保持不变
        function leaveMessage() {
            const input = document.getElementById('msgInput');
            const text = input.value.trim();
            
            if (text === '') {
                alert('输入为空，无法发送。');
                return;
            }

            const now = new Date();
            const timeString = now.toLocaleDateString() + ' ' + now.toLocaleTimeString();
            const newMsg = { text: text, time: timeString };

            let messages = JSON.parse(localStorage.getItem('myMessages')) || [];
            messages.unshift(newMsg);
            localStorage.setItem('myMessages', JSON.stringify(messages));

            input.value = '';
            loadMessages();
        }

        function loadMessages() {
            const msgList = document.getElementById('msgList');
            if (!msgList) return;
            
            const messages = JSON.parse(localStorage.getItem('myMessages')) || [];
            msgList.innerHTML = '';

            messages.forEach(msg => {
                const div = document.createElement('div');
                div.className = 'msg-item';
                div.innerHTML = `<div style="font-size: 0.8rem; color: #8892b0; margin-bottom: 5px;">📍 时间戳: ${msg.time}</div><div>${msg.text}</div>`;
                msgList.appendChild(div);
            });
        }
    </script>
    <button class="inline-flex h-12 animate-shimmer items-center justify-center rounded-md border border-slate-800 bg-[linear-gradient(110deg,#000,45%,#1e2631,55%,#000)] bg-[length:200%_100%] px-6 font-medium text-slate-400 transition-colors">
  极客实验室
</button>
</BaseLayout>