---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="黄金矿工终端 | 博雅的数字领地">
    <div class="hero">
        <h1>⛏️ 深海黄金矿工</h1>
        <p>利用重力钩爪，在暗物质领域中抓取价值核心。</p>
    </div>

    <div class="section" style="text-align: center;">
        <div style="margin-bottom: 10px; display: flex; justify-content: space-between; font-family: monospace;">
            <span id="scoreDisplay">SCORE: 000</span>
            <span id="timeDisplay">TIME: 60</span>
        </div>
        
        <canvas id="gameCanvas" width="740" height="400" style="background: rgba(0,0,0,0.5); border: 1px solid var(--accent-color); cursor: crosshair; max-width: 100%;"></canvas>
        
        <p style="margin-top: 15px; color: var(--text-muted); font-size: 0.8rem;">
            [ 指令说明 ]：按下 <kbd style="background: #333; padding: 2px 5px; border-radius: 3px;">空格键 (Space)</kbd> 或点击画面发射钩爪。
        </p>
    </div>

    <script>
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        const scoreEl = document.getElementById('scoreDisplay');
        const timeEl = document.getElementById('timeDisplay');

        // 游戏颜色配置 (沿用你的配色)
        const ACCENT = '#64ffda';
        const GOLD = '#ffd700';
        const STONE = '#8892b0';

        let score = 0;
        let timeLeft = 60;
        let gameActive = true;

        // 钩子状态
        const hook = {
            x: canvas.width / 2,
            y: 50,
            angle: 0,
            angleSpeed: 0.03,
            length: 40,
            state: 'swinging', // swinging, extending, retracting
            extendSpeed: 5,
            targetItem: null
        };

        // 物品生成
        const items = [];
        for (let i = 0; i < 8; i++) {
            items.push({
                x: Math.random() * (canvas.width - 100) + 50,
                y: Math.random() * (canvas.height - 150) + 120,
                radius: Math.random() > 0.7 ? 25 : 12, // 区分大小金块
                type: Math.random() > 0.3 ? 'gold' : 'stone',
                val: 0
            });
        }
        items.forEach(item => {
            item.val = item.type === 'gold' ? item.radius * 2 : item.radius;
        });

        // 核心循环
        function update() {
            if (!gameActive) return;

            // 1. 钩子逻辑
            if (hook.state === 'swinging') {
                hook.angle += hook.angleSpeed;
                if (Math.abs(hook.angle) > 1.2) hook.angleSpeed *= -1;
            } else if (hook.state === 'extending') {
                hook.length += hook.extendSpeed;
                // 碰到边界回缩
                if (hook.length > 500 || hook.endX < 0 || hook.endX > canvas.width || hook.endY > canvas.height) {
                    hook.state = 'retracting';
                }
                // 碰撞检测
                items.forEach((item, index) => {
                    const dx = hook.endX - item.x;
                    const dy = hook.endY - item.y;
                    if (Math.sqrt(dx*dx + dy*dy) < item.radius) {
                        hook.targetItem = items.splice(index, 1)[0];
                        hook.state = 'retracting';
                    }
                });
            } else if (hook.state === 'retracting') {
                const weight = hook.targetItem ? (hook.targetItem.radius / 5) : 1;
                hook.length -= hook.extendSpeed / weight;
                if (hook.length <= 40) {
                    hook.length = 40;
                    hook.state = 'swinging';
                    if (hook.targetItem) {
                        score += hook.targetItem.val;
                        scoreEl.innerText = `SCORE: ${score.toString().padStart(3, '0')}`;
                        hook.targetItem = null;
                    }
                }
            }

            // 计算钩子末端坐标
            hook.endX = hook.x + Math.sin(hook.angle) * hook.length;
            hook.endY = hook.y + Math.cos(hook.angle) * hook.length;

            draw();
            requestAnimationFrame(update);
        }

        function draw() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            // 画绳子
            ctx.beginPath();
            ctx.strokeStyle = ACCENT;
            ctx.lineWidth = 2;
            ctx.moveTo(hook.x, hook.y);
            ctx.lineTo(hook.endX, hook.endY);
            ctx.stroke();

            // 画钩子头
            ctx.fillStyle = ACCENT;
            ctx.beginPath();
            ctx.arc(hook.endX, hook.endY, 5, 0, Math.PI * 2);
            ctx.fill();

            // 画物品
            items.forEach(item => {
                ctx.fillStyle = item.type === 'gold' ? GOLD : STONE;
                ctx.beginPath();
                ctx.arc(item.x, item.y, item.radius, 0, Math.PI * 2);
                ctx.fill();
                // 加点赛博纹理
                ctx.strokeStyle = 'rgba(255,255,255,0.2)';
                ctx.stroke();
            });

            // 如果钩子抓到了东西
            if (hook.targetItem) {
                ctx.fillStyle = hook.targetItem.type === 'gold' ? GOLD : STONE;
                ctx.beginPath();
                ctx.arc(hook.endX, hook.endY, hook.targetItem.radius, 0, Math.PI * 2);
                ctx.fill();
            }
        }

        // 交互：空格或点击
        function handleInput(e) {
            if (e.code === 'Space' || e.type === 'mousedown') {
                if (hook.state === 'swinging') hook.state = 'extending';
            }
        }
        window.addEventListener('keydown', handleInput);
        canvas.addEventListener('mousedown', handleInput);

        // 倒计时
        const timerInterval = setInterval(() => {
            if (!gameActive) return;
            timeLeft--;
            timeEl.innerText = `TIME: ${timeLeft}`;
            if (timeLeft <= 0) {
                gameActive = false;
                clearInterval(timerInterval);
                alert(`任务结束！本次采集价值: ${score}`);
            }
        }, 1000);

        update();
    </script>
</BaseLayout>