---
import BaseLayout from '../../layouts/BaseLayout.astro';

// 🚀 底层引擎升级：调用 Vite 原生的 glob 抓取当前目录下所有 .md 文件 (完美适配 Astro v5)
const posts = Object.values(import.meta.glob('./*.md', { eager: true }));
---

<BaseLayout title="信号日志 | 博雅的数字领地">
    
    <div class="hero">
        <h1>📝 信号日志 (Blog)</h1>
        <p>记录代码、折腾 M4 硬件与日常生活的数据碎片。</p>
    </div>

    <div class="section">
        <h2>/> 最新输出指令</h2>
        
        <ul style="list-style: none; padding: 0; margin-top: 20px;">
            {posts.map((post: any) => (
                <li style="margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid rgba(255, 255, 255, 0.05);">
                    <a href={post.url} style="color: var(--accent-color); text-decoration: none; font-size: 1.3rem; font-weight: bold; transition: opacity 0.3s;">
                        {post.frontmatter.title}
                    </a>
                    <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 5px; font-family: monospace;">
                        时间戳：{post.frontmatter.pubDate || '未知时间'}
                    </div>
                    <p style="margin: 10px 0 0 0; color: var(--text-muted); font-size: 0.95rem;">
                        {post.frontmatter.description || '（此信号段暂无简介...）'}
                    </p>
                </li>
            ))}
        </ul>
        
    </div>
</BaseLayout>