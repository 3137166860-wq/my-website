---
// 这是所有页面的“母体骨架”
const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    
    <style is:global>
        :root {
            --bg-color: #050508; 
            --gradient-blue: linear-gradient(135deg, #0a192f 0%, #112240 100%); 
            --text-main: #ccd6f6; 
            --text-muted: #8892b0; 
            --accent-color: #64ffda; 
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            line-height: 1.6;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 60px 20px;
        }

        .hero {
            padding: 80px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }
        .hero h1 {
            font-size: 3rem;
            margin: 0 0 10px 0;
            background: linear-gradient(90deg, #fff, var(--text-muted));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .hero p {
            font-size: 1.2rem;
            color: var(--text-muted);
            max-width: 600px;
        }

        .section {
            background: var(--gradient-blue);
            border-radius: 16px;
            padding: 30px;
            margin-top: 40px;
            box-shadow: 0 10px 30px -15px rgba(2, 12, 27, 0.7);
            border: 1px solid rgba(255,255,255,0.05);
        }
        .section h2 {
            margin-top: 0;
            color: var(--text-main);
            display: flex;
            align-items: center;
        }
        .section h2::before {
            content: "/>";
            color: var(--accent-color);
            margin-right: 10px;
            font-family: monospace;
        }

        .tags { display: flex; gap: 10px; flex-wrap: wrap; }
        .tag {
            background: rgba(100, 255, 218, 0.1);
            color: var(--accent-color);
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 0.9rem;
            letter-spacing: 1px;
        }

        .message-box { display: flex; flex-direction: column; gap: 15px; }
        textarea {
            width: 100%;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: var(--text-main);
            padding: 15px;
            border-radius: 8px;
            box-sizing: border-box;
            resize: vertical;
            min-height: 100px;
            font-family: inherit;
        }
        textarea:focus { outline: none; border-color: var(--accent-color); }
        button {
            align-self: flex-start;
            background: transparent;
            color: var(--accent-color);
            border: 1px solid var(--accent-color);
            padding: 10px 25px;
            border-radius: 4px;
            cursor: pointer;
            font-weight: bold;
            transition: all 0.3s ease;
        }
        button:hover { background: rgba(100, 255, 218, 0.1); transform: translateY(-2px); }

        #msgList { margin-top: 30px; display: flex; flex-direction: column; gap: 15px; }
        .msg-item {
            background: rgba(0, 0, 0, 0.2);
            padding: 15px;
            border-radius: 8px;
            border-left: 3px solid var(--text-muted);
            font-size: 0.95rem;
        }
    </style>
</head>
<body>
    <div class="container">
        <slot />
    </div>
</body>
</html>