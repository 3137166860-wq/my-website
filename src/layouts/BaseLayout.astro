---
const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <style is:global>
        :root {
            --bg-color: #050508; 
            --gradient-blue: linear-gradient(135deg, #0a192f 0%, #112240 100%); 
            --text-main: #ccd6f6; 
            --text-muted: #8892b0; 
            --accent-color: #64ffda; 
        }

        body {
            margin: 0; padding: 0;
            font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            line-height: 1.6;
        }

        .container { max-width: 800px; margin: 0 auto; padding: 40px 20px; }

        nav {
            display: flex; gap: 20px; margin-bottom: 40px; padding: 15px 0;
            border-bottom: 1px solid rgba(100, 255, 218, 0.1);
        }
        nav a { color: var(--text-main); text-decoration: none; font-size: 0.9rem; letter-spacing: 1px; transition: color 0.3s; }
        nav a:hover { color: var(--accent-color); }

        .hero { padding: 60px 0; border-bottom: 1px solid rgba(255, 255, 255, 0.05); }
        .hero h1 { font-size: 3rem; margin: 0; background: linear-gradient(90deg, #fff, var(--text-muted)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .section { background: var(--gradient-blue); border-radius: 16px; padding: 30px; margin-top: 40px; border: 1px solid rgba(255,255,255,0.05); }
        .section h2 { color: var(--text-main); display: flex; align-items: center; margin-top: 0; }
        .section h2::before { content: "/>"; color: var(--accent-color); margin-right: 10px; font-family: monospace; }
        .tags { display: flex; gap: 10px; flex-wrap: wrap; }
        .tag { background: rgba(100, 255, 218, 0.1); color: var(--accent-color); padding: 5px 15px; border-radius: 20px; font-size: 0.8rem; }
        
        /* --- 极客新装备：页脚的 CSS 样式 --- */
        footer {
            margin-top: 80px;
            padding-top: 20px;
            border-top: 1px dashed rgba(136, 146, 176, 0.2);
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: var(--text-muted);
            font-size: 0.85rem;
            font-family: monospace;
        }
        footer a {
            color: var(--text-muted);
            text-decoration: none;
            margin-left: 15px;
            transition: color 0.3s;
        }
        footer a:hover { color: var(--accent-color); }
    </style>
</head>
<body>
    <div class="container">
        <nav>
            <a href="/">HOME // 首页</a>
            <a href="/games">TERMINAL // 游戏</a>
            <a href="/blog">BLOG // 博客</a>
            <a href="/about">ABOUT // 关于</a> </nav>

        <slot />

        <footer>
            <div>&copy; 2026 博雅的数字领地</div>
            <div>
                <a href="https://github.com/你的GitHub账号" target="_blank">GitHub</a>
                <a href="mailto:你的邮箱@example.com">Email</a>
            </div>
        </footer>
    </div>
</body>
</html>